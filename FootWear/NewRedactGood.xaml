<Window x:Class="FootWear.NewRedactGood"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FootWear"
        mc:Ignorable="d"
        Title="NewRedactGood" Height="750" Width="600" WindowStartupLocation="CenterScreen" Icon="pack://application:,,,/res/Icon.ico">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="7*"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="0.5*"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="0.5*"/>
        </Grid.RowDefinitions>
        
        <Grid Grid.Column="1" Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="0.2*"/>
            </Grid.RowDefinitions>
            <Image Name="ImageGood" Source="{Binding bytes}" Grid.Row="0" Width="300" Height="100" Stretch="Uniform" MouseDown="ImageGood_MouseDown" />
            <Label  Content="Фотография" Grid.Row="1" HorizontalContentAlignment="Center" MouseDown="ImageGood_MouseDown"/>
        </Grid>
        <Grid Grid.Column="1" Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Label Content="Артикул" Grid.Row="0"/>
            <TextBox Name="ArtickleGood" Grid.Row="1" FontFamily="Times New Roman" FontSize="20" MaxLength="6"/>
        </Grid>

        <Grid Grid.Column="1" Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Label Content="Название товара" Grid.Row="0"/>
            <TextBox Name="NameGood" Grid.Row="1" FontFamily="Times New Roman" FontSize="20"/>
        </Grid>
        
        <Grid Grid.Column="1" Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Label Content="Категория товара" Grid.Row="0"/>
            <ComboBox Name="CategoryGood" Grid.Row="1" FontFamily="Times New Roman" FontSize="16"/>
        </Grid>

        <Grid Grid.Column="1" Grid.Row="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Label Content="Описание товара" Grid.Row="0"/>
            <TextBox Name="DescriptionGood" Grid.Row="1" FontFamily="Times New Roman" FontSize="20"/>
        </Grid>

        <Grid Grid.Column="1" Grid.Row="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Label Content="Производитель товара" Grid.Row="0"/>
            <ComboBox Name="ManufacturerGood" Grid.Row="1" FontFamily="Times New Roman" FontSize="16"/>
        </Grid>

        <Grid Grid.Column="1" Grid.Row="7">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Label Content="Поставщик товара" Grid.Row="0"/>
            <ComboBox Name="SupplierGood" Grid.Row="1" FontFamily="Times New Roman" FontSize="16"/>
        </Grid>

        <Grid Grid.Column="1" Grid.Row="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Label Content="Стоимость товара" Grid.Row="0"/>
            <TextBox Name="PriceGood" Grid.Row="1" FontFamily="Times New Roman" FontSize="20"/>
        </Grid>

        <Grid Grid.Column="1" Grid.Row="9">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Label Content="Единица измерения" Grid.Row="0"/>
            <ComboBox Name="UnitGood" Grid.Row="1" FontFamily="Times New Roman" FontSize="16"/>
        </Grid>

        <Grid Grid.Column="1" Grid.Row="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Label Content="Количество на складе" Grid.Row="0"/>
            <TextBox Name="AmountOnSrtorageGood" Grid.Row="1" FontFamily="Times New Roman" FontSize="20"/>
        </Grid>

        <Grid Grid.Column="1" Grid.Row="11">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Label Content="Действующая скидка" Grid.Row="0"/>
            <TextBox Name="CurrentDiscountGood" Grid.Row="1" FontFamily="Times New Roman" FontSize="20"/>
        </Grid>

        <Button Name="SaveButton" Content="Сохранить" Grid.Column="1" Grid.Row="12" Width="200" Height="25" Click="SaveButton_Click"/>

    </Grid>
</Window>
