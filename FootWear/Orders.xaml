<Window x:Class="FootWear.Orders"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FootWear"
        xmlns:uc="clr-namespace:FootWear.UC"
        mc:Ignorable="d"
            Title="Заказы" Height="1080" Width="1920" Icon="pack://application:,,,/res/Icon.ico" WindowState="Maximized">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="3.5*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Image Grid.Column="0" Source="/res/Icon.JPG" Stretch="Uniform"/>
            <Label Name="title" Grid.Column="1" Content="Заказы" FontFamily="Times New Roman" FontSize="50" HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <Grid Grid.Column="2" Margin="0,0,10,0" >
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Button Grid.Row="0" x:Name="AddNewOrder" Click="AddNewOrder_Click"  Content="Добавить заказ"  FontFamily="Times New Roman" FontSize="20"   Height="30" Background="#00FA9A" HorizontalAlignment="Stretch"/>
                <Button Grid.Row="1" x:Name="back" Click="back_Click"  Content="Назад"  FontFamily="Times New Roman" FontSize="20"   Height="30" Background="#00FA9A" HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
            </Grid>


        </Grid>

        <ListView HorizontalContentAlignment="Stretch" x:Name="MainLW" Grid.Row="1" MouseDoubleClick="MainLW_MouseDoubleClick">
            <ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Удалить товар"
                      Click="Delete_Click"/>
                </ContextMenu>
            </ListView.ContextMenu>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <uc:OrdersControl DataContext="{Binding}"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListView>
    </Grid>
</Window>
