<Window x:Class="FootWear.RedactNewOrder"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FootWear"
        mc:Ignorable="d"
            Title="NewRedactGood" Height="500" Width="400" WindowStartupLocation="CenterScreen" Icon="pack://application:,,,/res/Icon.ico">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="7*"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="0.5*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            
            <RowDefinition Height="0.5*"/>
        </Grid.RowDefinitions>

        
        <Grid Grid.Column="1" Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Label Content="Артикул(через запятую если несколько)" Grid.Row="0"/>
            <TextBox Name="ArtickleOrder" Grid.Row="1" FontFamily="Times New Roman" FontSize="20" />
        </Grid>

        

        <Grid Grid.Column="1" Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Label Content="статус" Grid.Row="0"/>
            <ComboBox Name="StatusOrder" Grid.Row="1" FontFamily="Times New Roman" FontSize="16"/>
        </Grid>

        <Grid Grid.Column="1" Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Label Content="Адрес ПВ" Grid.Row="0"/>
            <ComboBox Name="AdressPickUpPoint" Grid.Row="1" FontFamily="Times New Roman" FontSize="16" DisplayMemberPath="FullAddress"/>
        </Grid>

        <Grid Grid.Column="1" Grid.Row="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Label Content="Дата заказа" Grid.Row="0"/>
            <DatePicker x:Name="DateStartPicker"
                Grid.Row="1"
                FontFamily="Times New Roman"
                FontSize="16"
                SelectedDateChanged="DateStartPicker_SelectedDateChanged"/>
        </Grid>

        <Grid Grid.Column="1" Grid.Row="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Label Content="Дата выдачи" Grid.Row="0"/>
            <DatePicker x:Name="DateDeliverPicker"
                Grid.Row="1"
                FontFamily="Times New Roman"
                FontSize="16"
                SelectedDateChanged="DateDeliverPicker_SelectedDateChanged"/>
        </Grid>

        <Grid Grid.Column="1" Grid.Row="7">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Label Content="id клиента" Grid.Row="0"/>
            <ComboBox Name="ClientId" Grid.Row="1" FontFamily="Times New Roman" FontSize="16"/>
        </Grid>

        <Button Name="SaveButton" Content="Сохранить" Grid.Column="1" Grid.Row="12" Width="200" Height="25" Click="SaveButton_Click"/>

    </Grid>
</Window>
